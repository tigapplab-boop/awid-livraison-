// ========================================
// AWID / BURGER MINUTE - Prisma Schema
// Adapted for SQLite (production will use PostgreSQL)
// ========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== UTILISATEURS (Livreurs + Admins) ====================
model User {
  id                 String  @id @default(uuid())
  phone              String? @unique
  name               String
  role               String  @default("LIVREUR") // LIVREUR | ADMIN
  password           String // bcrypt hash
  mustChangePassword Boolean @default(false)
  isAvailable        Boolean @default(true)

  // Horaires de disponibilité (JSON: {monday: {start: "09:00", end: "18:00"}, ...})
  availabilitySchedule String? // JSON string
  lastSeenAt           DateTime? // Dernière activité (pour afficher "en ligne")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ordersCreated     Order[]            @relation("AdminCreatedOrders")
  ordersAssigned    Order[]            @relation("LivreurOrders")
  pushSubscriptions PushSubscription[]

  @@map("users")
}

// ==================== CLIENTS (créés après validation livreur) ====================
model Client {
  id           String    @id @default(uuid())
  phone        String    @unique
  name         String?
  firstOrderAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tokens    ClientToken[]
  addresses ClientAddress[]
  orders    Order[]

  @@map("clients")
}

model ClientToken {
  id        String   @id @default(uuid())
  token     String   @unique
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  lastUsed  DateTime @updatedAt

  @@map("client_tokens")
}

model ClientAddress {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  label     String? // "Maison", "Bureau"
  address   String
  zone      String // VILLE | HORS_VILLE
  location  String? // JSON string: { lat, lng }
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("client_addresses")
}

// ==================== CATÉGORIES & PRODUITS ====================
model Category {
  id        String   @id @default(uuid())
  name      String
  nameAr    String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  products Product[]

  @@map("categories")
}

model Product {
  id            String   @id @default(uuid())
  name          String
  nameAr        String?
  description   String?
  descriptionAr String?
  price         Int // Centimes (ex: 45000 = 450 DA)
  image         String? // URL relative
  isAvailable   Boolean  @default(true)
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])

  // Promo banner fields
  hasPromo     Boolean @default(false)
  promoText    String? // Ex: "-20%", "Offre spéciale"
  promoTextAr  String?
  promoBgColor String? @default("#FF6B00") // Couleur de fond de la bannière

  // Product organization
  isNew     Boolean @default(false) // Badge "NOUVEAU" 
  sortOrder Int     @default(0) // Ordre d'affichage manuel

  // Stock management (pour boissons uniquement)
  stockQuantity Int?    @default(0) // Stock disponible (NULL si pas de gestion stock)
  minStockAlert Int?    @default(10) // Alerte si stock < X
  trackStock    Boolean @default(false) // true = décrémente auto à la commande
  unit          String? @default("unité") // "unité", "bouteille", "canette", "litre"

  createdAt DateTime @default(now())

  orderItems       OrderItem[]
  inventoryProduct InventoryProduct?

  @@map("products")
}

// ==================== COMMANDES DÉFINITIVES ====================
model Order {
  id          String @id @default(uuid())
  orderNumber String @unique // BM-YYMMDD-XXX
  type        String @default("ONLINE") // ONLINE | POS
  source      String @default("ONLINE") // ONLINE | PHONE_CALL
  status      String @default("PENDING") // PENDING | CONFIRMED | PREPARING | READY | DELIVERED | CANCELLED

  // Client (obligatoire après validation)
  clientId    String
  client      Client  @relation(fields: [clientId], references: [id])
  clientPhone String // Redondant pour recherche rapide
  clientToken String? // Token anonyme du navigateur

  // Livreur
  assignedLivreurId String?
  assignedLivreur   User?     @relation("LivreurOrders", fields: [assignedLivreurId], references: [id])
  createdByAdminId  String?
  createdByAdmin    User?     @relation("AdminCreatedOrders", fields: [createdByAdminId], references: [id])
  assignedAt        DateTime?

  // Livraison
  clientAddress   String
  deliveryZone    String // VILLE | HORS_VILLE
  deliveryFee     Int // Centimes
  isNightDelivery Boolean @default(false)

  // Finance
  subtotal Int
  total    Int

  // Cash livreur
  amountPaid       Int? // Ce que le client a réellement donné
  changeDue        Int? // Auto-calculé : amountPaid - total
  paymentIssue     String? @default("NONE") // NONE | CLIENT_SHORT_MONEY | CLIENT_NO_CHANGE | CLIENT_REFUSES_PAY | WRONG_ADDRESS | CLIENT_NOT_HOME | OTHER
  paymentIssueNote String?

  // Relations
  items OrderItem[]

  // Timestamps workflow
  createdAt    DateTime  @default(now())
  confirmedAt  DateTime?
  preparedAt   DateTime?
  readyAt      DateTime?
  pickedUpAt   DateTime?
  deliveredAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?

  notes         String?
  paymentMethod String  @default("CASH") // CASH only
  paymentStatus String  @default("PENDING") // PENDING | PAID | PARTIAL | REFUNDED | OFFERED

  // Traçabilité
  sourceTempId  String? // ID Redis de l'OrderTemp d'origine
  sourceVersion Int?

  @@index([status])
  @@index([assignedLivreurId])
  @@index([status, assignedLivreurId])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Int // Prix au moment de la commande (centimes)
  notes     String?

  // Sauces choisies pour cet item
  sauces OrderItemSauce[]

  @@map("order_items")
}

// ==================== ZONES LIVRAISON ====================
model DeliveryZone {
  id         String   @id @default(uuid())
  name       String // "Ville", "Hors Ville"
  dayFee     Int // Centimes
  nightFee   Int // Centimes
  startNight String // "19:00"
  endNight   String // "23:59"
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("delivery_zones")
}

// ==================== SUBSCRIPTIONS PUSH (Web Push VAPID) ====================
model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

// ==================== STATS JOURNALIÈRES ====================
model DailyStats {
  id                String   @id @default(uuid())
  date              DateTime @unique
  totalOrders       Int      @default(0)
  onlineOrders      Int      @default(0)
  posOrders         Int      @default(0)
  phoneOrders       Int      @default(0)
  totalRevenue      Int      @default(0)
  totalDeliveryFees Int      @default(0)
  cancelledOrders   Int      @default(0)
  partialPayments   Int      @default(0)
  offeredOrders     Int      @default(0)
  topProductId      String?

  @@map("daily_stats")
}

// ==================== SAUCES ====================
model Sauce {
  id          String   @id @default(uuid())
  name        String // Ex: "Sauce Algérienne"
  nameAr      String? // Ex: "صلصة جزائرية"
  isAvailable Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  // Relation avec commandes
  orderItemSauces OrderItemSauce[]

  @@map("sauces")
}

// Pivot: Sauces choisies pour un item de commande
model OrderItemSauce {
  id          String    @id @default(uuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  sauceId     String
  sauce       Sauce     @relation(fields: [sauceId], references: [id])

  @@map("order_item_sauces")
}

// ==================== INVENTAIRE - PRODUITS D'ACHAT ====================
model InventoryProduct {
  id       String  @id @default(uuid())
  name     String // "Coca Cola 1.5L"
  nameAr   String?
  supplier String // "Hamoud Boualem"
  category String // "Boissons", "Viandes", "Pain", etc.
  unit     String // "carton", "kg", "pièce", "litre"

  // Prix
  purchasePrice Int // Prix d'achat unitaire (centimes)
  sellingPrice  Int // Prix de vente unitaire (centimes)

  // Stock
  currentStock Float @default(0) // Stock actuel
  minStock     Float @default(0) // Alerte si < X

  // Relation avec produit menu (optionnel - pour boissons)
  linkedProductId String?  @unique
  linkedProduct   Product? @relation(fields: [linkedProductId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  purchases Purchase[]

  @@index([category])
  @@index([supplier])
  @@map("inventory_products")
}

// ==================== INVENTAIRE - ACHATS ====================
model Purchase {
  id             String @id @default(uuid())
  purchaseNumber String @unique // ACH-YYMMDD-XXX

  productId String
  product   InventoryProduct @relation(fields: [productId], references: [id])

  quantity    Float // 10 cartons, 5.5 kg, etc.
  unitPrice   Int // Prix unitaire d'achat (centimes)
  totalAmount Int // quantity × unitPrice

  supplier String // Nom grossiste

  // Paiement
  isPaid        Boolean   @default(false)
  paidAt        DateTime?
  paymentMethod String? // "Espèces", "Virement", "Chèque"

  notes         String?
  invoiceNumber String?
  purchaseDate  DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([isPaid])
  @@index([supplier])
  @@index([purchaseDate])
  @@map("purchases")
}

// ==================== PARAMÈTRES SYSTÈME ====================
model SystemSettings {
  id        String   @id @default(uuid())
  key       String   @unique // "MAIN_PROMO_BANNER", "COVER_IMAGE"
  value     String // JSON string
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
